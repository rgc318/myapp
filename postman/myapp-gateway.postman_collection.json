  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"usr\": \"{{username}}\",\n  \"pwd\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/method/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "method",
                "login"
              ]
            },
            "description": "Login to Frappe. Postman will keep the session cookie for subsequent requests."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"login succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Gateway",
      "item": [
        {
          "name": "search_product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/method/myapp.api.gateway.search_product?search_key={{search_key}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "method",
                "myapp.api.gateway.search_product"
              ],
              "query": [
                {
                  "key": "search_key",
                  "value": "{{search_key}}"
                },
                {
                  "key": "warehouse",
                  "value": "{{warehouse}}",
                  "disabled": true
                },
                {
                  "key": "company",
                  "value": "{{company}}",
                  "disabled": true
                },
                {
                  "key": "price_list",
                  "value": "{{price_list}}",
                  "disabled": true
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"search_product succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message.ok).to.eql(true);",
                  "  pm.expect(body.message.code).to.eql(\"PRODUCTS_FETCHED\");",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "create_order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{customer}}\",\n  \"items\": [\n    {\n      \"item_code\": \"{{item_code}}\",\n      \"qty\": 1,\n      \"warehouse\": \"{{warehouse}}\"\n    }\n  ],\n  \"company\": \"{{company}}\",\n  \"immediate\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/method/myapp.api.gateway.create_order",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "method",
                "myapp.api.gateway.create_order"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"create_order succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message.ok).to.eql(true);",
                  "  pm.expect(body.message.code).to.eql(\"ORDER_CREATED\");",
                  "  pm.environment.set(\"sales_order\", body.message.data.order || \"\");",
                  "  pm.environment.set(\"delivery_note\", body.message.data.delivery_note || \"\");",
                  "  pm.environment.set(\"sales_invoice\", body.message.data.sales_invoice || \"\");",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "create_order_invalid_warehouse",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{customer}}\",\n  \"items\": [\n    {\n      \"item_code\": \"{{item_code}}\",\n      \"qty\": 1,\n      \"warehouse\": \"{{invalid_warehouse}}\"\n    }\n  ],\n  \"company\": \"{{invalid_company}}\",\n  \"immediate\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/method/myapp.api.gateway.create_order",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "method",
                "myapp.api.gateway.create_order"
              ]
            },
            "description": "Expected to return a unified error envelope."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"create_order_invalid_warehouse returns unified error\", function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message.ok).to.eql(false);",
                  "  pm.expect(body.message.status).to.eql(\"error\");",
                  "  pm.expect(body.message.code).to.be.oneOf([\"VALIDATION_ERROR\", \"PERMISSION_DENIED\", \"INSUFFICIENT_STOCK\"]);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
