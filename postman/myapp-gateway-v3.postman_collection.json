              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"search_product succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message.ok).to.eql(true);",
