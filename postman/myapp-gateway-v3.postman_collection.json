        {
          "name": "create_order_step_by_step",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer\": \"{{customer}}\",\n  \"items\": [\n    {\n      \"item_code\": \"{{item_code}}\",\n      \"qty\": 1,\n      \"warehouse\": \"{{warehouse}}\"\n    }\n  ],\n  \"company\": \"{{company}}\",\n  \"immediate\": 0\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/method/myapp.api.gateway.create_order",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "method",
                "myapp.api.gateway.create_order"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"create_order_step_by_step succeeded\", function () {",
                  "  pm.response.to.have.status(200);",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.message.ok).to.eql(true);",
                  "  pm.expect(body.message.code).to.eql(\"ORDER_CREATED\");",
                  "  pm.environment.set(\"sales_order\", body.message.data.order || \"\");",
                  "  pm.environment.set(\"delivery_note\", body.message.data.delivery_note || \"\");",
                  "  pm.environment.set(\"sales_invoice\", body.message.data.sales_invoice || \"\");",
                  "});"
                ]
              }
            }
          ],
          "response": []
