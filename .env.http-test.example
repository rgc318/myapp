# HTTP test settings for devcontainer-based development.
# Copy this file to `.env.http-test` and fill in either token auth or username/password auth.

MYAPP_HTTP_BASE_URL=http://localhost:8080

# Preferred: API token auth
# MYAPP_HTTP_API_KEY=your-api-key
# MYAPP_HTTP_API_SECRET=your-api-secret

# Alternative: session login auth
MYAPP_HTTP_USERNAME=Administrator
MYAPP_HTTP_PASSWORD=your-password

# Response output controls
MYAPP_HTTP_PRINT_RESPONSES=1
MYAPP_HTTP_SAVE_RESPONSES=1
MYAPP_HTTP_RESULTS_FILE=apps/myapp/http-test-results.json
MYAPP_HTTP_ENABLE_CHAIN_TESTS=0

# Sample business data for successful sales-flow tests
MYAPP_TEST_CUSTOMER=Palmer Productions Ltd.
MYAPP_TEST_ITEM_CODE=SKU010
MYAPP_TEST_WAREHOUSE=Stores - RD
MYAPP_TEST_COMPANY=rgc (Demo)
MYAPP_TEST_QTY=1
MYAPP_TEST_PAID_AMOUNT=900

# Optional:
# You can run a single test method like this:
# python3 apps/myapp/myapp/tests/http/test_gateway_http.py \
#   GatewayHttpTestCase.test_search_product_with_empty_query_returns_success_shape
